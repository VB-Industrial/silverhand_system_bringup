[Unit]
Description=SilverHand system bringup (%i)
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/silver_ws
Environment=ROS_WS=%h/silver_ws
Environment=ROS_DISTRO=jazzy
Environment=AMENT_TRACE_SETUP_FILES=
ExecStart=%h/silver_ws/src/silverhand_system_bringup/scripts/start_system_%i.sh
Restart=on-failure
RestartSec=2
KillSignal=SIGINT
TimeoutStopSec=20

[Install]
WantedBy=default.target
